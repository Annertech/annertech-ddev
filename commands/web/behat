#!/bin/sh
#ddev-generated
#annertech-ddev

## Description: Run behat inside the web container
## Usage: behat [flags] [args]
## Example: "ddev behat --tags ~wip"

# Signal to PHP-FPM (via shared filesystem) that behat is running, so settings.php
# can disable modules like captcha and antibot that block automated requests.
touch /var/www/html/web/.behat_testing
trap "rm -f /var/www/html/web/.behat_testing" EXIT INT TERM

# Use project-root vendor/bin/behat if present
if [ -f "vendor/bin/behat" ]; then
    vendor/bin/behat -c tests/behat/behat.yml "$@"
    exit $?
fi

# Check if the tests/behat directory exists
if [ ! -d "tests/behat" ]; then
    echo
    echo "\033[38;5;208mError: Directory tests/behat does not exist.\033[0m"
    echo "\033[38;5;208mAre Behat tests defined for this project?\033[0m"
    echo
    exit 1
fi

# Navigate to the behat directory
cd tests/behat

# Always run 'composer install' in tests/behat to ensure dependencies are up-to-date
composer install

bin/behat "$@"

