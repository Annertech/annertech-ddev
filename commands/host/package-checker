#!/usr/bin/env bash
#ddev-generated
#annertech-ddev

## Description: Scan all GitLab projects for composer packages, flag insecure versions
## Usage: package-checker <vendor/package[:max-insecure-version]> [more...]
## Example: "ddev package-checker drupal/token" \n"ddev package-checker drupal/ai:2.8 drupal/paragraphs:1.9"
## Aliases: wtfiow

set -euo pipefail

# ==============================================================================
# package-checker (alias: wtfiow - "what the f* is on where")
# ------------------------------------------------------------------------------
# Offline scan of every project under a GitLab group (default: clients) for one
# or more composer packages, by reading each project's composer-manifest.yaml
# via the GitLab API. No clone, no composer. A project matches if it uses ANY
# of the given packages.
#
# Two backends, auto-selected:
#   * glab  - used when `glab` is installed. Auth + host come from glab itself
#             (`glab auth login` once); no tokens or URLs needed. Host is
#             auto-detected from the project git remote, or set GITLAB_HOST.
#   * curl  - fallback. Requires GITLAB_URL + GITLAB_TOKEN (read_api scope).
# Force one with PACKAGE_CHECKER_BACKEND=glab|curl.
#
#   ddev package-checker drupal/token              # list every project using it
#   ddev package-checker drupal/token:1.6           # flag installs <= 1.6
#   ddev package-checker drupal/ai:2.8 drupal/paragraphs:1.9   # multiple, OR-matched
#
# Env:
#   GITLAB_GROUP   group path to scan (default: clients)
#   GITLAB_HOST    (glab mode) force a glab host instead of auto-detect
#   GITLAB_URL     (curl mode) GitLab base URL, required
#   GITLAB_TOKEN   (curl mode) token with read_api scope, required
#   DEBUG          if set, log every scanned project + every missing manifest
#   PACKAGE_CHECKER_BACKEND  force "glab" or "curl"
# Deps: jq, plus either glab OR curl
# ==============================================================================

# parse args into parallel arrays: each "vendor/package[:max-insecure-version]"
[ "$#" -ge 1 ] || { echo "usage: ddev package-checker <vendor/package[:version]> [more...]" >&2; exit 1; }
PKGS=(); MAXES=()
for arg in "$@"; do
  if [[ "$arg" == *:* ]]; then
    PKGS+=("${arg%%:*}"); MAXES+=("${arg#*:}")
  else
    PKGS+=("$arg"); MAXES+=("")
  fi
done

GROUP="${GITLAB_GROUP:-clients}"
MANIFEST="composer-manifest.yaml"
GID="${GROUP//\//%2F}"   # url-encode any subgroup slashes

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'

# --- pick backend -------------------------------------------------------------
BACKEND="${PACKAGE_CHECKER_BACKEND:-}"
if [ -z "$BACKEND" ]; then
  if command -v glab >/dev/null 2>&1; then BACKEND=glab; else BACKEND=curl; fi
fi

if [ "$BACKEND" = "glab" ]; then
  command -v glab >/dev/null 2>&1 || { echo "ERROR: glab not installed." >&2; exit 1; }
  api=(glab api)
  [ -n "${GITLAB_HOST:-}" ] && api+=(--hostname "$GITLAB_HOST")

  list_projects() {
    "${api[@]}" --paginate \
      "groups/$GID/projects?include_subgroups=true&archived=false&per_page=100" \
      | jq -rs '.[][] | select(.archived != true) | "\(.id)\t\(.path_with_namespace)\t\(.default_branch // "main")"'
  }
  get_manifest() { # <id> <branch>
    "${api[@]}" "projects/$1/repository/files/$MANIFEST/raw?ref=$2" 2>/dev/null
  }
  preflight() {
    # glab defaults to gitlab.com when the host can't be inferred from the git
    # remote, silently returning 0 projects. Treat empty as a config error.
    local n
    n=$(list_projects 2>/dev/null | grep -c . || true)
    if [ "${n:-0}" -eq 0 ]; then
      echo "ERROR: glab returned 0 projects for group '$GROUP'." >&2
      echo "  Run from a project on the right GitLab, 'glab auth login'," >&2
      echo "  or set GITLAB_HOST to your GitLab host." >&2
      exit 1
    fi
  }
else
  : "${GITLAB_URL:?curl backend needs GITLAB_URL (your GitLab base URL)}"
  : "${GITLAB_TOKEN:?curl backend needs GITLAB_TOKEN (read_api scope)}"
  hdr=(--header "PRIVATE-TOKEN: $GITLAB_TOKEN")

  list_projects() {
    local page=1 resp
    while :; do
      resp=$(curl -sf "${hdr[@]}" \
        "$GITLAB_URL/api/v4/groups/$GID/projects?include_subgroups=true&archived=false&per_page=100&page=$page")
      [ "$(jq length <<<"$resp")" -eq 0 ] && break
      jq -r '.[] | select(.archived != true) | "\(.id)\t\(.path_with_namespace)\t\(.default_branch // "main")"' <<<"$resp"
      page=$((page+1))
    done
  }
  get_manifest() { # <id> <branch>
    curl -sf "${hdr[@]}" "$GITLAB_URL/api/v4/projects/$1/repository/files/$MANIFEST/raw?ref=$2"
  }
  preflight() {
    local probe
    probe=$(curl -s -o /dev/null -w '%{http_code}' "${hdr[@]}" "$GITLAB_URL/api/v4/groups/$GID")
    case "$probe" in
      200) ;;
      401) echo "ERROR: 401 unauthorized - bad/expired GITLAB_TOKEN." >&2; exit 1 ;;
      404) echo "ERROR: 404 - group '$GROUP' not found or token lacks access." >&2; exit 1 ;;
      *)   echo "ERROR: GitLab returned HTTP $probe for group '$GROUP'." >&2; exit 1 ;;
    esac
  }
fi

# is version <= max ?  (strip leading v, compare with sort -V)
is_insecure() { # <version> <max>
  local v="${1#v}" m="${2#v}"
  [ "$v" = "$m" ] && return 0
  [ "$(printf '%s\n%s\n' "$v" "$m" | sort -V | head -1)" = "$v" ]
}

echo "Scanning group '$GROUP' (backend: $BACKEND) ..." >&2
preflight

scanned=0; nomanifest=0
# each element: "repo<TAB>insecure(0|1)<TAB>pkg ver"  (aggregated per repo below)
matches=()
# dedup projects by id: pagination/subgroups can list the same repo twice, which
# would otherwise inflate the scanned count and duplicate matches.
while IFS=$'\t' read -r id name branch; do
  scanned=$((scanned+1))
  [ -n "${DEBUG:-}" ] && echo "  scanning: $name ($branch)" >&2

  if ! raw=$(get_manifest "$id" "$branch"); then
    nomanifest=$((nomanifest+1))
    [ -n "${DEBUG:-}" ] && echo "  no manifest: $name ($branch)" >&2
    continue
  fi

  # check each requested package against this project's manifest
  for i in "${!PKGS[@]}"; do
    pkg="${PKGS[$i]}"; max="${MAXES[$i]}"

    # manifest line: "    vendor/pkg: version"  (exact package match)
    # `|| true` so a non-match (grep exit 1) does not trip pipefail/set -e.
    line=$(grep -E "^[[:space:]]+${pkg//\//\\/}:[[:space:]]" <<<"$raw" || true)
    [ -z "$line" ] && continue   # project does not use this package
    ver=$(head -1 <<<"$line" | sed -E 's/.*:[[:space:]]*//; s/[[:space:]]*$//')

    if [ -z "$max" ]; then
      matches+=("$name"$'\t'"0"$'\t'"$pkg $ver")
    elif is_insecure "$ver" "$max"; then
      matches+=("$name"$'\t'"1"$'\t'"$pkg $ver (<= $max)")
    fi
    # secure versions are not printed
  done
done < <(list_projects | awk -F'\t' '!seen[$1]++')

echo "------------------------------------------------"

# real-escape colors for awk (no echo -e needed inside it)
GC=$'\033[0;32m'; RC=$'\033[0;31m'; NCC=$'\033[0m'

hits=0; repos=0
if [ "${#matches[@]}" -gt 0 ]; then
  # collapse identical (repo,pkg) rows, then aggregate one line per repo with
  # packages sorted; a repo turns red if any of its matches is insecure.
  uniq_rows=$(printf '%s\n' "${matches[@]}" | sort -t$'\t' -k1,1 -k3,3 -u)
  printf '%s\n' "$uniq_rows" \
    | awk -F'\t' -v G="$GC" -v R="$RC" -v N="$NCC" '
        function emit(){ printf "%s%s%s REQUIRES %s\n", (bad?R:G), cur, N, list }
        { if ($1 != cur) { if (cur != "") emit(); cur=$1; list=$3; bad=($2=="1") }
          else { list=list ", " $3; if ($2=="1") bad=1 } }
        END { if (cur != "") emit() }'
  hits=$(printf '%s\n' "$uniq_rows" | grep -c .)
  repos=$(printf '%s\n' "$uniq_rows" | cut -f1 | sort -u | grep -c .)
fi

echo "------------------------------------------------"
echo "Scanned $scanned project(s); $nomanifest without $MANIFEST on default branch." >&2
if [ "$hits" -gt 0 ]; then
  echo -e "${YELLOW}$hits match(es) across $repos repo(s) for: ${PKGS[*]}.${NC}"
else
  echo -e "${GREEN}No uses of ${PKGS[*]} found.${NC}"
fi
