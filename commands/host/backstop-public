## Description: Copy BackstopJS HTML report into the web root to serve it via the web server
## Usage: backstop-public
## Example: "ddev backstop-public"
## ProjectTypes: drupal10,drupal11

BACKSTOP_DATA="${DDEV_APPROOT}/tests/backstop/backstop_data"
DEST="${DDEV_APPROOT}/web/sites/default/files/backstop_data"

if [ ! -d "${BACKSTOP_DATA}/html_report" ]; then
  echo "Report directory not found: ${BACKSTOP_DATA}/html_report"
  echo "Run BackstopJS first to generate a report."
  exit 1
fi

cp -r "${BACKSTOP_DATA}" "${DEST}"
echo "Report available at: ${DDEV_PRIMARY_URL}/sites/default/files/backstop_data/html_report/index.html"
