#!/usr/bin/env bash
#ddev-generated
#annertech-ddev

## Description: Drupal Operations Centre (libraries, utilities)
## Usage: drupal-operations-center
## Example: "ddev drupal-operations-center"
## Aliases: drupal-operations

# Colours
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo_red() { echo -e "${RED}$1${NC}" >&2; }
echo_green() { echo -e "${GREEN}$1${NC}" >&2; }
echo_yellow() { echo -e "${YELLOW}$1${NC}" >&2; }

OPTIONS=(
    "1. Download js-cookie library"
)

echo_green "Drupal"
echo_green "Operations"
echo_green "Centre"
echo "by Annertech"
echo "and Bill Seremetis"
echo ""

action_selection=$(printf '%s\n' "${OPTIONS[@]}" | fzf --reverse --height=50% --header="Action" -1)

if [[ -z "$action_selection" ]]; then
    echo_red "Nothing selected... Exiting"
    exit 0
fi

action_label=$(echo "$action_selection" | sed 's/^[0-9]*\. //')

case "$action_label" in
    "Download js-cookie library")
        echo_green "Downloading js-cookie library..."
        curl --create-dirs -o web/libraries/js-cookie/dist/js.cookie.min.js \
            https://cdn.jsdelivr.net/npm/js-cookie@3.0.5/dist/js.cookie.min.js
        echo ""
        echo_yellow "See README: https://git.drupalcode.org/project/js_cookie/-/blob/2.x/README.md"
        ;;
    *)
        echo_red "Unknown action: $action_label"
        exit 1
        ;;
esac
