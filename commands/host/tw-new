#!/usr/bin/env bash
#ddev-generated
#annertech-ddev

## Description: Create a new Teamwork task
## Usage: tw-new
## Example: "ddev tw-new"

set -eo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
echo_red()    { echo -e "${RED}$1${NC}" >&2; }
echo_green()  { echo -e "${GREEN}$1${NC}"; }
echo_yellow() { echo -e "${YELLOW}$1${NC}"; }

# Get Teamwork API key from environment
TW_API_KEY="${TEAMWORK_API_KEY:-}"
if [ -z "$TW_API_KEY" ]; then
    echo_red "Error: TEAMWORK_API_KEY environment variable not set"
    echo_yellow "Set it with: export TEAMWORK_API_KEY='your-api-key'"
    exit 1
fi

# Check for jq
if ! command -v jq &> /dev/null; then
    echo_red "Error: jq is required for this command"
    echo_yellow "Install with: apt-get install jq (or brew install jq on macOS)"
    exit 1
fi

# Check for fzf
if ! command -v fzf &> /dev/null; then
    echo_red "Error: fzf is required for this command"
    echo_yellow "Install with: apt-get install fzf (or brew install fzf on macOS)"
    exit 1
fi

# Read project ID from .env.anner if available
TW_PROJECT_ID=""
ENV_FILE=".ddev/.env.anner"
if [ -f "$ENV_FILE" ]; then
    TW_PROJECT_ID=$(grep -E '^TEAMWORK_PROJECT_ID=' "$ENV_FILE" | cut -d= -f2 | tr -d '"' | tr -d "'" || true)
fi

# Select project
if [ -n "$TW_PROJECT_ID" ]; then
    echo_yellow "Using project ID from .env.anner: $TW_PROJECT_ID"
    PROJECT_ID="$TW_PROJECT_ID"
else
    echo_yellow "Fetching active projects..."
    PROJECTS_RESPONSE=$(curl -s \
        -u "${TW_API_KEY}:v" \
        "https://projects.annertech.com/projects.json?status=active")

    if [ -z "$PROJECTS_RESPONSE" ]; then
        echo_red "Error: Failed to fetch projects from API"
        exit 1
    fi

    STATUS=$(echo "$PROJECTS_RESPONSE" | jq -r '.STATUS')
    if [[ "$STATUS" != "OK" ]]; then
        echo_red "Error fetching projects: $(echo "$PROJECTS_RESPONSE" | jq -r '.MESSAGE // "Unknown error"')"
        exit 1
    fi

    PROJECT_SELECTION=$(echo "$PROJECTS_RESPONSE" | \
        jq -r '.projects[] | "\(.id)\t\(.name) (\(.id))"' | \
        fzf --reverse --height=50% --header="Select Project" --delimiter=$'\t' --with-nth=2 -1)

    if [ -z "$PROJECT_SELECTION" ]; then
        echo_red "No project selected. Aborting."
        exit 0
    fi

    PROJECT_ID=$(echo "$PROJECT_SELECTION" | cut -f1)
fi

# Fetch task lists for selected project
echo_yellow "Fetching task lists..."
TASKLISTS_RESPONSE=$(curl -s \
    -u "${TW_API_KEY}:v" \
    "https://projects.annertech.com/projects/${PROJECT_ID}/tasklists.json")

if [ -z "$TASKLISTS_RESPONSE" ]; then
    echo_red "Error: Failed to fetch task lists from API"
    exit 1
fi

TL_STATUS=$(echo "$TASKLISTS_RESPONSE" | jq -r '.STATUS')
if [[ "$TL_STATUS" != "OK" ]]; then
    echo_red "Error fetching task lists: $(echo "$TASKLISTS_RESPONSE" | jq -r '.MESSAGE // "Unknown error"')"
    exit 1
fi

TASKLISTS_COUNT=$(echo "$TASKLISTS_RESPONSE" | jq '.tasklists | length')
if [[ "$TASKLISTS_COUNT" == "0" ]]; then
    echo_red "No task lists found for this project. You need at least one task list to create a task."
    exit 1
fi

TASKLIST_SELECTION=$(echo "$TASKLISTS_RESPONSE" | \
    jq -r '.tasklists[] | "\(.id)\t\(.name)"' | \
    fzf --reverse --height=50% --header="Select Task List" --delimiter=$'\t' --with-nth=2 -1)

if [ -z "$TASKLIST_SELECTION" ]; then
    echo_red "No task list selected. Aborting."
    exit 0
fi

TASKLIST_ID=$(echo "$TASKLIST_SELECTION" | cut -f1)

# Get task title
read -e -r -p "$(echo -e "${YELLOW}Task title: ${NC}")" CARD_TITLE
if [ -z "$CARD_TITLE" ]; then
    echo_red "Task title is required. Aborting."
    exit 1
fi

# Get multiline description (Markdown supported, Ctrl+D to submit)
echo_yellow "Enter description — Markdown supported (Ctrl+D on an empty line to finish):"
CARD_DESC=$(cat)

# Build JSON payload
DATA=$(jq -n \
    --arg name "$CARD_TITLE" \
    --arg desc "$CARD_DESC" \
    '{ "todo-item": { "content": $name, "description": $desc } }')

# Create the task
echo_yellow "Creating task..."
RESPONSE=$(curl -s -w "\n%{http_code}" -X POST \
    -H "Content-Type: application/json" \
    -u "${TW_API_KEY}:v" \
    -d "$DATA" \
    "https://projects.annertech.com/tasklists/${TASKLIST_ID}/tasks.json")

HTTP_CODE=$(echo "$RESPONSE" | tail -n1)
BODY=$(echo "$RESPONSE" | head -n-1)

if [ "$HTTP_CODE" -eq 201 ] || [ "$HTTP_CODE" -eq 200 ]; then
    NEW_TASK_ID=$(echo "$BODY" | jq -r '.id')
    echo_green "✓ Task created successfully"
    echo_green "https://projects.annertech.com/tasks/${NEW_TASK_ID}"
else
    echo_red "✗ Failed to create task (HTTP $HTTP_CODE)"
    echo "$BODY"
    exit 1
fi
