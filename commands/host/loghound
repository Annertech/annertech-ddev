def parse_ip_filters(specs: list[str]) -> list[ipaddress.IPv4Network | ipaddress.IPv6Network]:
    """Parse a list of IP or CIDR strings into network objects."""
    nets = []
    for s in specs:
        try:
            nets.append(ipaddress.ip_network(s, strict=False))
        except ValueError as e:
            raise SystemExit(f"loghound: invalid --ip value {s!r}: {e}") from None
    return nets


def ip_matches(ip_str: str, nets: list) -> bool:
    try:
        addr = ipaddress.ip_address(ip_str)
    except ValueError:
        return False
    return any(addr in net for net in nets)


def iter_records(paths: Iterable[str], agg: Aggregator,
                 since: int | None, until: int | None,
                 ip_filter: list | None = None) -> None:
    for path in paths:
        with open_log(path) as f:
            for line in f:
                rec = parse_line(line)
                if rec is None:
                    agg.malformed += 1
                    continue
                if since is not None and rec[1] < since:
                    continue
                if until is not None and rec[1] > until:
                    continue
                if ip_filter and not ip_matches(rec[0], ip_filter):
                    continue
                agg.feed(rec)


def parse_iso(s: str | None) -> int | None:
    if not s:
        return None
    dt = datetime.fromisoformat(s)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return int(dt.timestamp())


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(
        prog="loghound",
        description="Fast offline Apache access log forensics. Stdlib only.",
    )
    p.add_argument("files", nargs="*", help="log files (.log, .gz, .bz2, or - for stdin)")
    p.add_argument("--since", help="ISO8601 lower bound, UTC if naive")
    p.add_argument("--until", help="ISO8601 upper bound, UTC if naive")
    p.add_argument("--top", type=int, default=20, help="rows per table (default 20)")
    p.add_argument("--flood-rpm", type=int, default=60,
                   help="req/min threshold for flood (default 60)")
    p.add_argument("--flood-sustained", type=int, default=2,
                   help="minutes >= flood-rpm required to flag (default 2)")
    p.add_argument("--subnet-min-ips", type=int, default=5,
                   help="distinct IPs in /24 to flag a cluster (default 5)")
    p.add_argument("--subnet-min-requests", type=int, default=100,
                   help="min requests across the /24 to flag (default 100)")
    p.add_argument("--spike-multiplier", type=float, default=3.0,
                   help="× median req/hour to flag a spike (default 3.0)")
    p.add_argument("--business-start", type=int, default=9, help="UTC hour, default 9")
    p.add_argument("--business-end", type=int, default=17, help="UTC hour, default 17")
    p.add_argument("--ip", metavar="IP/CIDR", action="append", default=[],
                   help="filter to this IP or subnet (repeatable, e.g. --ip 1.2.3.4 --ip 10.0.0.0/8)")
    p.add_argument("--focus", choices=("5xx", "4xx", "botnet", "flood", "spike"),
                   help="run one module only (faster reporting, same parse)")
    p.add_argument("--json", action="store_true", help="emit JSON only on stdout")
    p.add_argument("--json-out", metavar="PATH", help="also write JSON to PATH")
    p.add_argument("--quiet", action="store_true", help="suppress narrative summary")
    p.add_argument("--no-color", action="store_true")
    args = p.parse_args(argv)

    if not args.files:
        candidates = sorted(_glob.glob("logs/*access.log") + _glob.glob("logs/*access.log.gz") + _glob.glob("logs/*access.log.bz2"))
        if not candidates:
            p.error("no *access.log files found in logs/ - pass a file explicitly or run ddev ucc to download one")
        if len(candidates) == 1:
            args.files = candidates
        else:
            sys.stderr.write("Available log files:\n")
            for i, name in enumerate(candidates, 1):
                sys.stderr.write(f"  [{i}] {name}\n")
            sys.stderr.write("Select file(s) [1]: ")
            try:
                raw = input().strip() or "1"
            except (EOFError, KeyboardInterrupt):
                return 1
            selected = []
            for token in raw.split():
                if "-" in token:
                    lo, _, hi = token.partition("-")
                    selected.extend(range(int(lo), int(hi) + 1))
                else:
                    selected.append(int(token))
            try:
                args.files = [candidates[i - 1] for i in selected]
            except IndexError:
                p.error("selection out of range")

    since = parse_iso(args.since)
    until = parse_iso(args.until)
    ip_filter = parse_ip_filters(args.ip) if args.ip else None

    agg = Aggregator(top=args.top)
    iter_records(args.files, agg, since, until, ip_filter)

    color = (not args.no_color) and sys.stdout.isatty() and not args.json
    style = Style(color=color)

    # Build report into a buffer so we can swallow it under --json.
    buf = io.StringIO()
    js = render_report(agg, args, buf, style)

    if args.json:
        json.dump(js, sys.stdout, default=str, indent=2)
        sys.stdout.write("\n")
    else:
        sys.stdout.write(buf.getvalue())

    if args.json_out:
        with open(args.json_out, "w", encoding="utf-8") as f:
            json.dump(js, f, default=str, indent=2)

    return 0


if __name__ == "__main__":
    sys.exit(main())
