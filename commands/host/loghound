class Style:
    def __init__(self, color: bool):
        self.color = color

    def h(self, s):  # section header
        return f"\033[1;36m{s}\033[0m" if self.color else s

    def warn(self, s):
        return f"\033[1;33m{s}\033[0m" if self.color else s

    def bad(self, s):
        return f"\033[1;31m{s}\033[0m" if self.color else s

    def dim(self, s):
        return f"\033[2m{s}\033[0m" if self.color else s

    def link(self, url: str, label: str | None = None) -> str:
        """Always return the full URL as plain text."""
        return url


def fmt_int(n: int) -> str:
    return f"{n:,}"


def fmt_ts(epoch: int | None) -> str:
    if epoch is None:
        return "n/a"
    return datetime.fromtimestamp(epoch, tz=timezone.utc).isoformat()


def render_table(rows: list[tuple], headers: tuple[str, ...], out) -> None:
    if not rows:
        out.write("  (none)\n")
        return
    widths = [len(h) for h in headers]
    str_rows = []
    for r in rows:
        sr = tuple(str(c) for c in r)
        str_rows.append(sr)
        for i, c in enumerate(sr):
            if len(c) > widths[i]:
                widths[i] = min(len(c), 80)
    fmt = "  " + "  ".join("{:<" + str(w) + "}" for w in widths) + "\n"
    out.write(fmt.format(*headers))
    out.write("  " + "  ".join("-" * w for w in widths) + "\n")
    for sr in str_rows:
        truncated = tuple(c[:80] for c in sr)
        out.write(fmt.format(*truncated))


def render_report(agg: Aggregator, args, out, style: Style) -> dict:
    """Print human report; also build & return the JSON shape."""
    js: dict = {}

    # Run all detections once up front so results can be reused.
    floods = detect_floods(agg, args.flood_rpm, args.flood_sustained)
    clusters = detect_subnet_clusters(agg, args.subnet_min_ips, args.subnet_min_requests)

    # ---------- Header
    out.write(style.h("=" * 78) + "\n")
    out.write(style.h("LOGHOUND  -  Apache access log forensics report") + "\n")
    out.write(style.h("=" * 78) + "\n")
    out.write(f"Lines parsed     : {fmt_int(agg.lines)}\n")
    out.write(f"Malformed        : {fmt_int(agg.malformed)}\n")
    out.write(f"Time range (UTC) : {fmt_ts(agg.first_ts)}  →  {fmt_ts(agg.last_ts)}\n")
    js["meta"] = {
        "lines": agg.lines,
        "malformed": agg.malformed,
        "first_ts": fmt_ts(agg.first_ts),
        "last_ts": fmt_ts(agg.last_ts),
    }

    focus = args.focus

    # ---------- Status overview
    if not focus or focus == "5xx":
        out.write("\n" + style.h("Status code totals") + "\n")
        rows = [(s, fmt_int(c)) for s, c in agg.status_total.most_common()]
        render_table(rows, ("status", "count"), out)
        js["status_totals"] = dict(agg.status_total)

    # ---------- 5xx deep dive (most important)
    fivexx_codes = sorted(s for s in agg.status_total if 500 <= s < 600)
    if fivexx_codes and (not focus or focus == "5xx"):
        out.write("\n" + style.bad("=== 5xx DEEP DIVE  (downtime / server failures) ===") + "\n")
        js["fivexx"] = {}
        for code in fivexx_codes:
            n = agg.status_total[code]
            out.write("\n" + style.bad(f"HTTP {code}  ({fmt_int(n)} requests)") + "\n")
            first_e = agg.fivexx_first.get(code)
            last_e = agg.fivexx_last.get(code)
            peak_min, peak_n = (None, 0)
            if agg.fivexx_minute[code]:
                peak_min, peak_n = max(agg.fivexx_minute[code].items(), key=lambda kv: kv[1])
            out.write(f"  window : {fmt_ts(first_e)}  →  {fmt_ts(last_e)}\n")
            if peak_min:
                out.write(f"  peak   : {fmt_ts(peak_min * 60)}  ({fmt_int(peak_n)} req in 1 min)\n")
            out.write(style.dim("\n  Top client IPs:\n"))
            render_table(
                [
                    (ip, fmt_int(c),
                     agg.ip_known.get(ip, ""),
                     style.link(f"https://www.abuseipdb.com/check/{ip}"))
                    for ip, c in agg.fivexx_ip[code].most_common(args.top)
                ],
                ("ip", "hits", "known", "check"),
                out,
            )
            out.write(style.dim("\n  Top request paths:\n"))
            render_table(
                [(p, fmt_int(c)) for p, c in agg.fivexx_path[code].most_common(args.top)],
                ("path", "hits"),
                out,
            )
            out.write(style.dim("\n  Top user agents:\n"))
            render_table(
                [(ua, fmt_int(c)) for ua, c in agg.fivexx_ua[code].most_common(args.top)],
                ("user-agent", "hits"),
                out,
            )
            out.write(style.dim("\n  Top referers:\n"))
            render_table(
                [(r, fmt_int(c)) for r, c in agg.fivexx_ref[code].most_common(args.top)],
                ("referer", "hits"),
                out,
            )
            js["fivexx"][str(code)] = {
                "count": n,
                "window_start": fmt_ts(first_e),
                "window_end": fmt_ts(last_e),
                "peak_minute_utc": fmt_ts(peak_min * 60) if peak_min else None,
                "peak_minute_count": peak_n,
                "top_ips": agg.fivexx_ip[code].most_common(args.top),
                "top_paths": agg.fivexx_path[code].most_common(args.top),
                "top_user_agents": agg.fivexx_ua[code].most_common(args.top),
                "top_referers": agg.fivexx_ref[code].most_common(args.top),
            }

    # ---------- 404
    if not focus or focus == "4xx":
        if agg.fourxx_path:
            out.write("\n" + style.h("=== 404 SCAN ===") + "\n")
            out.write(style.dim("\n  Top missing paths:\n"))
            render_table(
                [(p, fmt_int(c)) for p, c in agg.fourxx_path.most_common(args.top)],
                ("path", "hits"),
                out,
            )
            out.write(style.dim("\n  Top IPs hitting 404s:\n"))
            render_table(
                [(ip, fmt_int(c), agg.ip_known.get(ip, ""))
                 for ip, c in agg.fourxx_ip.most_common(args.top)],
                ("ip", "hits", "known"),
                out,
            )
            js["fourxx"] = {
                "top_paths": agg.fourxx_path.most_common(args.top),
                "top_ips": agg.fourxx_ip.most_common(args.top),
            }

    # ---------- IP clusters
    if not focus or focus == "botnet":
        out.write("\n" + style.warn("=== IP CLUSTERS  (≥ "
                                    f"{args.subnet_min_ips} IPs, ≥ "
                                    f"{fmt_int(args.subnet_min_requests)} reqs - "
                                    f"possible botnet, CDN, or shared network) ===") + "\n")
        def _cluster_known(c):
            svcs = {agg.ip_known[ip] for ip in c["sample_ips"] if ip in agg.ip_known}
            if not svcs:
                svcs = {agg.ip_known[ip] for ip in agg.ip_total
                        if subnet24(ip) == c["subnet"] and ip in agg.ip_known}
            return ",".join(sorted(svcs)) if svcs else ""
        rows = [(c["subnet"], c["ip_count"], fmt_int(c["total_requests"]),
                 _cluster_known(c), ", ".join(c["sample_ips"]))
                for c in clusters[:args.top]]
        render_table(rows, ("subnet", "#ips", "requests", "known", "sample"), out)
        js["ip_clusters"] = clusters[:args.top]

    # ---------- Floods
    if not focus or focus == "flood":
        out.write("\n" + style.warn(f"=== POSSIBLE IP FLOODS  (≥ {args.flood_rpm} req/min for ≥ "
                                    f"{args.flood_sustained} min - {VERDICT_CHECK_FURTHER}) ===") + "\n")
        rows = [(f["ip"], fmt_int(f["total_requests"]), f["peak_rpm"],
                 f["minutes_over_threshold"], f["peak_minute_utc"],
                 agg.ip_known.get(f["ip"], ""))
                for f in floods[:args.top]]
        render_table(rows, ("ip", "total", "peak rpm", "min>thr", "peak minute", "known"), out)
        js["floods"] = floods[:args.top]

    # ---------- Crawlers
    if not focus:
        out.write("\n" + style.h("=== DECLARED CRAWLERS ===") + "\n")
        render_table(
            [(name, fmt_int(c)) for name, c in agg.crawler_hits.most_common(args.top)],
            ("crawler", "hits"),
            out,
        )
        undeclared = detect_undeclared_crawlers(agg)
        out.write("\n" + style.warn("=== POSSIBLE UNDECLARED CRAWLERS  (browser UA, "
                                    f"≥ 500 distinct paths - {VERDICT_CHECK_FURTHER}) ===") + "\n")
        rows = [(u["ip"], u["distinct_paths_seen"], fmt_int(u["total_requests"]),
                 "yes" if u["had_any_referer"] else "no",
                 (u["user_agents"][0] if u["user_agents"] else "")[:60])
                for u in undeclared[:args.top]]
        render_table(rows, ("ip", "paths", "total", "ref?", "ua"), out)
        js["declared_crawlers"] = dict(agg.crawler_hits)
        js["possible_undeclared_crawlers"] = undeclared[:args.top]

    # ---------- Traffic spikes
    if not focus or focus == "spike":
        spikes = detect_traffic_spikes(
            agg, args.business_start, args.business_end, args.spike_multiplier
        )
        out.write("\n" + style.h(f"=== TRAFFIC SPIKES  (business hours "
                                 f"{args.business_start:02d}:00–"
                                 f"{args.business_end:02d}:00 UTC, "
                                 f"≥ {args.spike_multiplier}× median) ===") + "\n")
        out.write(style.dim("  Heuristic: e.g. mid-day spikes often indicate email "
                            "campaigns or promotions.\n"))
        rows = [(s["hour_utc"], fmt_int(s["requests"]),
                 fmt_int(s["baseline_median"]), s["multiple_of_baseline"])
                for s in spikes]
        render_table(rows, ("hour", "requests", "median", "x median"), out)
        js["traffic_spikes"] = spikes

    # ---------- Hourly histogram
    if not focus:
        out.write("\n" + style.h("=== HOURLY REQUEST HISTOGRAM ===") + "\n")
        hist_rows = []
        max_total = max(agg.hour_total.values()) if agg.hour_total else 1
        for hour in sorted(agg.hour_total):
            total = agg.hour_total[hour]
            cls = agg.hour_class[hour]
            bar_len = int(40 * total / max_total)
            hist_rows.append((
                datetime.fromtimestamp(hour, tz=timezone.utc).strftime("%Y-%m-%d %H:%M"),
                fmt_int(total),
                fmt_int(cls.get(2, 0)),
                fmt_int(cls.get(3, 0)),
                fmt_int(cls.get(4, 0)),
                fmt_int(cls.get(5, 0)),
                "█" * bar_len,
            ))
        render_table(hist_rows, ("hour", "total", "2xx", "3xx", "4xx", "5xx", ""), out)

    # ---------- Candidates for blocking
    if not focus or focus in ("botnet", "flood"):
        flood_by_ip = {f["ip"]: f for f in floods}
        cluster_by_subnet = {c["subnet"]: c for c in clusters[:args.top]}
        block_subnets = list(cluster_by_subnet.keys())
        candidate_ips: list[str] = [f["ip"] for f in floods[:args.top]]
        for code in fivexx_codes:
            for ip, _ in agg.fivexx_ip[code].most_common(args.top):
                if ip not in candidate_ips:
                    candidate_ips.append(ip)

        subnet_set = set(block_subnets)
        leftover_ips = [ip for ip in candidate_ips if subnet24(ip) not in subnet_set]
        derived_ranges, lone_ips = derive_ip_ranges(leftover_ips, min_ips=3)

        # Severity scoring: combines volume + how many 5xx errors that source
        # caused (errors weighted heavier than benign hits).
        def ip_severity(ip: str) -> tuple[int, int, int]:
            total = agg.ip_total.get(ip, 0)
            errs = sum(agg.fivexx_ip[c].get(ip, 0) for c in fivexx_codes)
            peak = flood_by_ip[ip]["peak_rpm"] if ip in flood_by_ip else 0
            return total + errs * 4, errs, peak

        def subnet_severity(sn: str) -> tuple[int, int, int]:
            c = cluster_by_subnet.get(sn)
            if not c:
                # Derived range - sum from members
                members = [ip for ip in leftover_ips if subnet24(ip) == sn]
                total = sum(agg.ip_total.get(ip, 0) for ip in members)
                errs = sum(
                    sum(agg.fivexx_ip[code].get(ip, 0) for code in fivexx_codes)
                    for ip in members
                )
                return total + errs * 4, errs, len(members)
            errs = 0
            for code in fivexx_codes:
                for ip, n in agg.fivexx_ip[code].items():
                    if subnet24(ip) == sn:
                        errs += n
            return c["total_requests"] + errs * 4, errs, c["ip_count"]

        # Compute global max severity for normalised bars.
        all_scores: list[int] = []
        for sn in block_subnets + derived_ranges:
            all_scores.append(subnet_severity(sn)[0])
        for ip in lone_ips:
            all_scores.append(ip_severity(ip)[0])
        max_score = max(all_scores) if all_scores else 1

        def severity_label(score: int) -> str:
            ratio = score / max_score if max_score else 0
            if ratio >= 0.66:
                return style.bad("CRIT")
            if ratio >= 0.33:
                return style.warn("HIGH")
            return style.dim("MED ")

        def bar(score: int, width: int = 24) -> str:
            n = int(round(width * score / max_score)) if max_score else 0
            return "█" * n + style.dim("·" * (width - n))

        # Helpers: annotate and filter known good actors.
        # A subnet/IP is a "likely false positive" when:
        #   - more than half its IPs are tagged as declared crawlers, OR
        #   - its error rate is below 2% AND it is not a flood offender.
        # These are still shown in the detailed table (with a warning tag) so
        # analysts can see them, but excluded from the copy-paste block.
        CRAWLER_ERR_FLOOR = 0.02   # 2 % error rate
        CRAWLER_FRAC_FLOOR = 0.50  # 50 % of IPs must be crawler-tagged

        def subnet_ips(sn: str) -> list[str]:
            c = cluster_by_subnet.get(sn)
            if c:
                return [ip for ip in agg.ip_total if subnet24(ip) == sn]
            return [ip for ip in leftover_ips if subnet24(ip) == sn]

        def _known_tag_for_ips(ips: list[str]) -> str:
            services = {agg.ip_known[ip] for ip in ips if ip in agg.ip_known}
            return f" KNOWN:{','.join(sorted(services))}" if services else ""

        def verdict_subnet(sn: str) -> tuple[bool, str]:
            ips = subnet_ips(sn)
            cfrac = crawler_fraction_for_ips(ips, agg)
            erate = error_rate_for_ips(ips, agg)
            ktag = _known_tag_for_ips(ips)
            if cfrac >= CRAWLER_FRAC_FLOOR:
                names = {agg.ip_crawler[ip] for ip in ips if ip in agg.ip_crawler}
                return True, f"{VERDICT_LIKELY_CRAWLER} [{','.join(sorted(names)[:2])}]{ktag}"
            if erate < CRAWLER_ERR_FLOOR:
                return True, f"{VERDICT_LIKELY_BENIGN} [err:{erate:.1%}]{ktag}"
            if erate >= 0.10:
                return False, f"{VERDICT_HIGH_ERROR_RATE}{ktag}"
            return False, f"{VERDICT_CHECK_FURTHER}{ktag}"

        def verdict_ip(ip: str) -> tuple[bool, str]:
            ktag = f" KNOWN:{agg.ip_known[ip]}" if ip in agg.ip_known else ""
            if ip in agg.ip_crawler:
                return True, f"{VERDICT_LIKELY_CRAWLER} [{agg.ip_crawler[ip]}]{ktag}"
            total = agg.ip_total.get(ip, 0)
            errs = sum(agg.fivexx_ip[c].get(ip, 0) for c in fivexx_codes)
            erate = errs / total if total else 0
            if erate < CRAWLER_ERR_FLOOR:
                if ip in flood_by_ip:
                    return True, f"{VERDICT_HIGH_VOLUME} [err:{erate:.1%}]{ktag}"
                return True, f"{VERDICT_LIKELY_BENIGN} [err:{erate:.1%}]{ktag}"
            if ip in flood_by_ip and erate >= CRAWLER_ERR_FLOOR:
                return False, f"{VERDICT_FLOOD_WITH_ERRORS}{ktag}"
            if erate >= 0.10:
                return False, f"{VERDICT_HIGH_ERROR_RATE}{ktag}"
            return False, f"{VERDICT_CHECK_FURTHER}{ktag}"

        out.write("\n" + style.h(f"=== CANDIDATES FOR BLOCKING  (CIDR - {VERDICT_REVIEW_BEFORE_ACTING}) ===") + "\n")

        def render_subnet_block(title: str, subnets: list[str]):
            out.write(style.dim(f"\n  {title}\n"))
            out.write(f"    {'sev':<5} {'cidr':<22} {'reqs':>9} {'5xx':>7} {'#ips':>5}  bar  note\n")
            scored = sorted(subnets, key=lambda s: subnet_severity(s)[0], reverse=True)
            for sn in scored:
                score, errs, n_ips = subnet_severity(sn)
                if sn in cluster_by_subnet:
                    total_reqs = cluster_by_subnet[sn]["total_requests"]
                else:
                    members = [ip for ip in leftover_ips if subnet24(ip) == sn]
                    total_reqs = sum(agg.ip_total.get(ip, 0) for ip in members)
                _benign, v_note = verdict_subnet(sn)
                note = style.dim(f"[{v_note}]")
                out.write(
                    f"    {severity_label(score)}  {sn:<22} "
                    f"{fmt_int(total_reqs):>9} {fmt_int(errs):>7} {n_ips:>5}  "
                    f"{bar(score)}  {note}\n"
                )

        if block_subnets:
            render_subnet_block("Detected subnet clusters:", block_subnets)
        if derived_ranges:
            render_subnet_block("Derived IP ranges (≥ 3 IPs share a /24):", derived_ranges)
        if lone_ips:
            out.write(style.dim("\n  Individual IPs (not part of a detected range):\n"))
            out.write(f"    {'sev':<5} {'cidr':<22} {'reqs':>9} {'5xx':>7} {'rpm':>5}  bar  note\n")
            scored_ips = sorted(lone_ips, key=lambda i: ip_severity(i)[0], reverse=True)
            for ip in scored_ips:
                score, errs, peak = ip_severity(ip)
                total = agg.ip_total.get(ip, 0)
                _benign, v_note = verdict_ip(ip)
                note = style.dim(f"[{v_note}]")
                ratio = score / max_score if max_score else 0
                if ratio >= 0.33:  # CRIT or HIGH - add AbuseIPDB link
                    abuse_url = f"https://www.abuseipdb.com/check/{ip}"
                    note = (note + "  " if note else "") + style.link(abuse_url, "abuseipdb")
                out.write(
                    f"    {severity_label(score)}  {ip + '/32':<22} "
                    f"{fmt_int(total):>9} {fmt_int(errs):>7} {peak:>5}  "
                    f"{bar(score)}  {note}\n"
                )
        if not (block_subnets or derived_ranges or lone_ips):
            out.write("  (none)\n")

        # Plain CIDR list - top offenders only, false positives excluded.
        top_cidrs: list[str] = []
        all_cidrs_scored: list[tuple[int, str]] = []
        for sn in block_subnets + derived_ranges:
            if not verdict_subnet(sn)[0]:
                all_cidrs_scored.append((subnet_severity(sn)[0], sn))
        for ip in lone_ips:
            if not verdict_ip(ip)[0]:
                all_cidrs_scored.append((ip_severity(ip)[0], ip + "/32"))
        all_cidrs_scored.sort(reverse=True)
        if all_cidrs_scored:
            top_threshold = all_cidrs_scored[0][0] * 0.33  # CRIT+HIGH band
            top_cidrs = [cidr for score, cidr in all_cidrs_scored if score >= top_threshold]
            top_cidrs = top_cidrs[:max(1, args.top)]
        skipped_fp = (len(block_subnets) + len(derived_ranges) + len(lone_ips)) - len([
            1 for sn in block_subnets + derived_ranges if not verdict_subnet(sn)[0]
        ]) - len([1 for ip in lone_ips if not verdict_ip(ip)[0]])
        fp_note = f"  ({skipped_fp} likely benign source(s) excluded - see table above)\n" if skipped_fp else ""
        out.write(style.dim(f"\n  Copy-paste - top {len(top_cidrs)} candidate(s) (CIDR per line, {VERDICT_REVIEW_BEFORE_ACTING}):\n"))
        if fp_note:
            out.write(style.dim(fp_note))
        for cidr in top_cidrs:
            out.write(f"    {cidr}\n")

        js["suggested_block"] = {
            "subnets": [
                {"cidr": sn, "severity_score": subnet_severity(sn)[0],
                 "fivexx_hits": subnet_severity(sn)[1]}
                for sn in block_subnets
            ],
            "derived_ranges": [
                {"cidr": sn, "severity_score": subnet_severity(sn)[0],
                 "fivexx_hits": subnet_severity(sn)[1]}
                for sn in derived_ranges
            ],
            "ips": [
                {"cidr": ip + "/32", "severity_score": ip_severity(ip)[0],
                 "fivexx_hits": ip_severity(ip)[1],
                 "total_requests": agg.ip_total.get(ip, 0)}
                for ip in lone_ips
            ],
        }

    # ---------- Executive summary
    if not focus:
        summary = build_summary(agg, args, floods=floods, clusters=clusters)
        out.write("\n" + style.h("=== EXECUTIVE SUMMARY ===") + "\n")
        out.write(summary + "\n")
        js["executive_summary"] = summary

    return js


def build_summary(agg: Aggregator, args,
                   floods: list[dict] | None = None,
                   clusters: list[dict] | None = None) -> str:
    total = agg.lines
    fivexx_total = sum(c for s, c in agg.status_total.items() if 500 <= s < 600)
    fourxx_total = sum(c for s, c in agg.status_total.items() if 400 <= s < 500)
    twoxx_total = sum(c for s, c in agg.status_total.items() if 200 <= s < 300)
    if floods is None:
        floods = detect_floods(agg, args.flood_rpm, args.flood_sustained)
    if clusters is None:
        clusters = detect_subnet_clusters(agg, args.subnet_min_ips, args.subnet_min_requests)

    lines = []

    # --- Overview
    lines.append("## Overview\n")
    lines.append(f"- **Period (UTC):** {fmt_ts(agg.first_ts)} → {fmt_ts(agg.last_ts)}")
    lines.append(f"- **Total requests:** {fmt_int(total)}")
    if total == 0:
        lines.append("- (no matching records)")
        return "\n".join(lines)
    lines.append(f"- **Successful (2xx):** {fmt_int(twoxx_total)} ({twoxx_total * 100 / total:.1f}%)")
    if fivexx_total:
        lines.append(f"- **Server errors (5xx):** {fmt_int(fivexx_total)} ({fivexx_total * 100 / total:.1f}%) ⚠")
    if fourxx_total:
        lines.append(f"- **Client errors (4xx):** {fmt_int(fourxx_total)} ({fourxx_total * 100 / total:.1f}%)")

    # --- Incident detail
    if fivexx_total:
        worst = max(
            (s for s in agg.status_total if 500 <= s < 600),
            key=lambda s: agg.status_total[s],
        )
        first_e = agg.fivexx_first.get(worst)
        last_e = agg.fivexx_last.get(worst)
        peak_min, peak_n = (None, 0)
        if agg.fivexx_minute[worst]:
            peak_min, peak_n = max(agg.fivexx_minute[worst].items(), key=lambda kv: kv[1])

        lines.append("\n## Incident\n")
        lines.append(f"- **Dominant error:** HTTP {worst} "
                     f"({fmt_int(agg.status_total[worst])} hits, "
                     f"{agg.status_total[worst] * 100 / total:.1f}% of traffic)")
        if first_e and last_e:
            lines.append(f"- **Window:** {fmt_ts(first_e)} → {fmt_ts(last_e)}")
        if peak_min:
            lines.append(f"- **Peak minute:** {fmt_ts(peak_min * 60)} "
                         f"({fmt_int(peak_n)} req in that minute)")

        top_ip, top_ip_n = next(iter(agg.fivexx_ip[worst].most_common(1)), (None, 0))
        if top_ip:
            lines.append(f"- **Top contributing IP:** {top_ip} ({fmt_int(top_ip_n)} hits - {VERDICT_CHECK_FURTHER})")

    # --- Indicators
    indicator_lines = []
    if clusters:
        top = clusters[0]
        indicator_lines.append(
            f"- **Largest IP cluster:** `{top['subnet']}` - "
            f"{top['ip_count']} IPs, {fmt_int(top['total_requests'])} requests "
            f"(possible botnet, CDN, or shared network - {VERDICT_CHECK_FURTHER})"
        )
        if len(clusters) > 1:
            indicator_lines.append(f"- **Other notable clusters:** {len(clusters) - 1} additional cluster(s) detected")
    if floods:
        indicator_lines.append(
            f"- **Possible IP floods:** {len(floods)} IP(s) exceeded {args.flood_rpm} req/min "
            f"(top: `{floods[0]['ip']}` @ {floods[0]['peak_rpm']} rpm - {VERDICT_CHECK_FURTHER})"
        )
    if indicator_lines:
        lines.append("\n## Indicators\n")
        lines.extend(indicator_lines)

    # --- Suggested next steps
    lines.append("\n## Suggested next steps\n")
    lines.append(f"- Review the **Candidates for blocking** section - {VERDICT_REVIEW_BEFORE_ACTING}.")
    lines.append("- Cross-reference flagged IPs against the 5xx deep dive and AbuseIPDB before blocking.")
    lines.append("- This is an offline heuristic report; verify findings with live traffic data and WAF logs.")

    return "\n".join(lines)


