MONTHS = {
    b"Jan": 1, b"Feb": 2, b"Mar": 3, b"Apr": 4, b"May": 5, b"Jun": 6,
    b"Jul": 7, b"Aug": 8, b"Sep": 9, b"Oct": 10, b"Nov": 11, b"Dec": 12,
}
MONTHS_S = {k.decode(): v for k, v in MONTHS.items()}


def parse_apache_time(ts: str) -> int:
    # ts looks like: 30/Mar/2026:04:25:55 +0000
    # Manual parse - strptime is the bottleneck on ~1M lines.
    try:
        day = int(ts[0:2])
        mon = MONTHS_S[ts[3:6]]
        year = int(ts[7:11])
        hh = int(ts[12:14])
        mm = int(ts[15:17])
        ss = int(ts[18:20])
        # Timezone offset like +0000 or -0500
        sign = 1 if ts[21] == "+" else -1
        tz_h = int(ts[22:24])
        tz_m = int(ts[24:26])
        offset = sign * (tz_h * 3600 + tz_m * 60)
        # datetime → epoch (UTC) without pulling tzinfo per call.
        epoch = int(datetime(year, mon, day, hh, mm, ss, tzinfo=timezone.utc).timestamp())
        return epoch - offset
    except (ValueError, KeyError, IndexError):
        raise ValueError(f"bad timestamp: {ts!r}")


def parse_line(line: str):
    """Return (ip, epoch, method, path, status, size, referer, ua) or None.

    Hot path. No regex. Returns None for malformed lines.
    """
    try:
        sp = line.find(" ")
        if sp < 0:
            return None
        ip = line[:sp]

        lb = line.find("[", sp)
        rb = line.find("]", lb)
        if lb < 0 or rb < 0:
            return None
        epoch = parse_apache_time(line[lb + 1:rb])

        # Request quoted string
        q1 = line.find('"', rb)
        q2 = line.find('"', q1 + 1)
        if q1 < 0 or q2 < 0:
            return None
        request = line[q1 + 1:q2]
        # Split into method / path / proto without allocating extras.
        s1 = request.find(" ")
        s2 = request.rfind(" ")
        if s1 < 0:
            method = request
            path = ""
        else:
            method = request[:s1]
            path = request[s1 + 1:s2] if s2 > s1 else request[s1 + 1:]

        # status, size after the closing request quote
        rest = line[q2 + 2:]
        try:
            sp1 = rest.find(" ")
            status = int(rest[:sp1])
            sp2 = rest.find(" ", sp1 + 1)
            size_tok = rest[sp1 + 1:sp2]
            size = 0 if size_tok == "-" else int(size_tok)
        except (ValueError, IndexError):
            return None

        # Referer + UA: last two "..." in line.
        # rfind from end - UA is the last quoted, referer the second-last.
        end = len(line)
        # Strip trailing newline / whitespace
        while end > 0 and line[end - 1] in "\r\n ":
            end -= 1
        if end == 0 or line[end - 1] != '"':
            return (ip, epoch, method, path, status, size, "-", "-")
        ua_q2 = end - 1
        ua_q1 = line.rfind('"', 0, ua_q2)
        ref_q2 = line.rfind('"', 0, ua_q1)
        ref_q1 = line.rfind('"', 0, ref_q2) if ref_q2 > 0 else -1
        ua = line[ua_q1 + 1:ua_q2] if ua_q1 >= 0 else "-"
        referer = line[ref_q1 + 1:ref_q2] if ref_q1 >= 0 and ref_q2 > 0 else "-"
        return (ip, epoch, method, path, status, size, referer, ua)
    except Exception:
        return None


def open_log(path: str):
    if path == "-":
        return sys.stdin
    if path.endswith(".gz"):
        return io.TextIOWrapper(gzip.open(path, "rb"), encoding="utf-8", errors="replace")
    if path.endswith(".bz2"):
        return io.TextIOWrapper(bz2.open(path, "rb"), encoding="utf-8", errors="replace")
    return open(path, "r", encoding="utf-8", errors="replace")


