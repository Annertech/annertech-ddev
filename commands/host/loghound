VERDICT_CHECK_FURTHER = "check further"
VERDICT_LIKELY_BENIGN = "likely benign"
VERDICT_LIKELY_CRAWLER = "likely crawler - verify intent"
VERDICT_HIGH_ERROR_RATE = "high error rate - investigate"
VERDICT_HIGH_VOLUME = "high volume - check if legitimate"
VERDICT_FLOOD_WITH_ERRORS = "flood + errors - investigate"
VERDICT_REVIEW_BEFORE_ACTING = "review before acting"


def crawler_fraction_for_ips(ips: list[str], agg: Aggregator) -> float:
    """Return fraction of IPs (0.0–1.0) tagged as declared crawlers."""
    if not ips:
        return 0.0
    return sum(1 for ip in ips if ip in agg.ip_crawler) / len(ips)


def error_rate_for_ips(ips: list[str], agg: Aggregator) -> float:
    """Return 5xx / total request ratio across the given IPs."""
    total = sum(agg.ip_total.get(ip, 0) for ip in ips)
    if not total:
        return 0.0
    fivexx_codes = [s for s in agg.status_total if 500 <= s < 600]
    errs = sum(
        agg.fivexx_ip[code].get(ip, 0)
        for ip in ips
        for code in fivexx_codes
    )
    return errs / total

def detect_floods(agg: Aggregator, rpm_threshold: int, sustained_minutes: int) -> list[dict]:
    """Return IPs whose req/min exceeded threshold for >= sustained_minutes minutes."""
    out = []
    for ip, minutes in agg.ip_minute.items():
        if not minutes:
            continue
        offending = [(m, c) for m, c in minutes.items() if c >= rpm_threshold]
        if len(offending) < sustained_minutes:
            continue
        peak_min, peak_rpm = max(minutes.items(), key=lambda kv: kv[1])
        out.append({
            "ip": ip,
            "total_requests": agg.ip_total[ip],
            "peak_rpm": peak_rpm,
            "peak_minute_utc": datetime.fromtimestamp(peak_min * 60, tz=timezone.utc).isoformat(),
            "minutes_over_threshold": len(offending),
        })
    out.sort(key=lambda d: d["peak_rpm"], reverse=True)
    return out


def detect_subnet_clusters(agg: Aggregator, min_ips: int, min_requests: int) -> list[dict]:
    by_24: dict[str, list[int]] = defaultdict(list)  # subnet -> [requests per ip]
    by_24_ips: dict[str, set[str]] = defaultdict(set)
    for ip, count in agg.ip_total.items():
        s = subnet24(ip)
        by_24[s].append(count)
        by_24_ips[s].add(ip)
    out = []
    for s, counts in by_24.items():
        n_ips = len(by_24_ips[s])
        total = sum(counts)
        if n_ips >= min_ips and total >= min_requests:
            out.append({
                "subnet": s,
                "ip_count": n_ips,
                "total_requests": total,
                "sample_ips": sorted(by_24_ips[s])[:5],
            })
    out.sort(key=lambda d: d["total_requests"], reverse=True)
    return out


def derive_ip_ranges(ips: list[str], min_ips: int = 3) -> tuple[list[str], list[str]]:
    """Group IPs by /24; return (ranges, lone_ips).

    A /24 with >= min_ips members is emitted as a CIDR range; the rest are
    returned as individual IPs to be blocked at /32.
    """
    by_24: dict[str, list[str]] = defaultdict(list)
    for ip in ips:
        by_24[subnet24(ip)].append(ip)
    ranges, lone = [], []
    for sn, members in by_24.items():
        if len(members) >= min_ips:
            ranges.append(sn)
        else:
            lone.extend(members)
    ranges.sort()
    lone.sort()
    return ranges, lone


def detect_undeclared_crawlers(agg: Aggregator, min_distinct_paths: int = 500) -> list[dict]:
    out = []
    for ip, paths in agg.ip_paths.items():
        if len(paths) < min_distinct_paths:
            continue
        uas = agg.ip_uas[ip]
        # If declared, skip (already in declared crawler bucket).
        if any(any(tok in ua for tok in CRAWLER_UA_TOKENS) for ua in uas):
            continue
        out.append({
            "ip": ip,
            "distinct_paths_seen": len(paths),  # capped at 1000
            "total_requests": agg.ip_total[ip],
            "had_any_referer": agg.ip_has_referer.get(ip, False),
            "user_agents": sorted(uas)[:3],
        })
    out.sort(key=lambda d: d["distinct_paths_seen"], reverse=True)
    return out


def detect_traffic_spikes(agg: Aggregator, business_start: int, business_end: int, multiplier: float) -> list[dict]:
    if not agg.hour_total:
        return []
    counts = list(agg.hour_total.values())
    baseline = statistics.median(counts) or 1
    out = []
    for hour, total in sorted(agg.hour_total.items()):
        dt = datetime.fromtimestamp(hour, tz=timezone.utc)
        if total >= baseline * multiplier and business_start <= dt.hour < business_end:
            out.append({
                "hour_utc": dt.isoformat(),
                "requests": total,
                "baseline_median": baseline,
                "multiple_of_baseline": round(total / baseline, 1),
            })
    return out


