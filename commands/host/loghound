def _load_known_ips() -> dict[str, list]:
    """Load known_ips.json → {service_name: [ip_network, ...]}."""
    here = os.path.dirname(os.path.abspath(__file__))
    path = os.path.join(here, "known_ips.json")
    if not os.path.isfile(path):
        return {}
    with open(path, "r", encoding="utf-8") as f:
        raw = json.load(f)
    result: dict[str, list] = {}
    for key, cidrs in raw.items():
        if key.startswith("_"):
            continue
        result[key] = [ipaddress.ip_network(c, strict=False) for c in cidrs]
    return result


KNOWN_IP_RANGES: dict[str, list] = _load_known_ips()


def lookup_known_ip(ip_str: str) -> str | None:
    """Return the service name if ip_str falls in a known range, else None."""
    try:
        addr = ipaddress.ip_address(ip_str)
    except ValueError:
        return None
    for service, nets in KNOWN_IP_RANGES.items():
        for net in nets:
            if addr in net:
                return service
    return None


