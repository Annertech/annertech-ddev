def subnet24(ip: str) -> str:
    # Cheap /24 grouping for IPv4. IPv6 → /48 by colons.
    if "." in ip:
        i = ip.rfind(".")
        return ip[:i] + ".0/24" if i > 0 else ip
    parts = ip.split(":")
    if len(parts) >= 3:
        return ":".join(parts[:3]) + "::/48"
    return ip


def subnet16(ip: str) -> str:
    if "." in ip:
        a = ip.find(".")
        b = ip.find(".", a + 1)
        return ip[:b] + ".0.0/16" if b > 0 else ip
    parts = ip.split(":")
    if len(parts) >= 2:
        return ":".join(parts[:2]) + "::/32"
    return ip


class Aggregator:
    def __init__(self, top: int = 20):
        self.top = top
        self.lines = 0
        self.malformed = 0
        self.first_ts: int | None = None
        self.last_ts: int | None = None

        self.status_total: Counter[int] = Counter()
        # per-hour bucket -> Counter of status class (2,3,4,5)
        self.hour_class: dict[int, Counter[int]] = defaultdict(Counter)
        self.hour_total: Counter[int] = Counter()

        # 5xx detail: status -> structures
        self.fivexx_ip: dict[int, Counter[str]] = defaultdict(Counter)
        self.fivexx_path: dict[int, Counter[str]] = defaultdict(Counter)
        self.fivexx_ua: dict[int, Counter[str]] = defaultdict(Counter)
        self.fivexx_ref: dict[int, Counter[str]] = defaultdict(Counter)
        self.fivexx_minute: dict[int, Counter[int]] = defaultdict(Counter)
        self.fivexx_first: dict[int, int] = {}
        self.fivexx_last: dict[int, int] = {}

        # 404 detail
        self.fourxx_path: Counter[str] = Counter()
        self.fourxx_ip: Counter[str] = Counter()

        # IP totals + per-minute (for flood detection)
        self.ip_total: Counter[str] = Counter()
        self.ip_minute: dict[str, Counter[int]] = defaultdict(Counter)
        self.ip_paths: dict[str, set[str]] = defaultdict(set)
        self.ip_uas: dict[str, set[str]] = defaultdict(set)
        self.ip_has_referer: dict[str, bool] = defaultdict(bool)

        # Crawlers (declared)
        self.crawler_hits: Counter[str] = Counter()
        # Per-IP crawler tag: ip -> crawler name (first match wins)
        self.ip_crawler: dict[str, str] = {}

        # Known IP tag: ip -> service name (Googlebot, Bingbot, NodePing)
        self.ip_known: dict[str, str] = {}

    def feed(self, rec) -> None:
        ip, epoch, _method, path, status, _size, referer, ua = rec
        self.lines += 1
        if self.first_ts is None or epoch < self.first_ts:
            self.first_ts = epoch
        if self.last_ts is None or epoch > self.last_ts:
            self.last_ts = epoch

        self.status_total[status] += 1
        hour = epoch - (epoch % 3600)
        cls = status // 100
        self.hour_class[hour][cls] += 1
        self.hour_total[hour] += 1

        self.ip_total[ip] += 1
        minute = epoch // 60
        self.ip_minute[ip][minute] += 1

        # Bound the per-IP path/UA sets to keep memory in check on huge logs.
        if len(self.ip_paths[ip]) < 1000:
            self.ip_paths[ip].add(path)
        if len(self.ip_uas[ip]) < 16:
            self.ip_uas[ip].add(ua)
        if referer and referer != "-":
            self.ip_has_referer[ip] = True

        if 500 <= status < 600:
            self.fivexx_ip[status][ip] += 1
            self.fivexx_path[status][path] += 1
            self.fivexx_ua[status][ua] += 1
            self.fivexx_ref[status][referer] += 1
            self.fivexx_minute[status][minute] += 1
            self.fivexx_first[status] = min(self.fivexx_first.get(status, epoch), epoch)
            self.fivexx_last[status] = max(self.fivexx_last.get(status, epoch), epoch)

        if status == 404:
            self.fourxx_path[path] += 1
            self.fourxx_ip[ip] += 1

        # Declared crawler check (substring match - cheap and good enough)
        for tok in CRAWLER_UA_TOKENS:
            if tok in ua:
                self.crawler_hits[tok] += 1
                if ip not in self.ip_crawler:
                    self.ip_crawler[ip] = tok
                break

        # Known IP range check (only on first encounter per IP)
        if ip not in self.ip_known and KNOWN_IP_RANGES:
            svc = lookup_known_ip(ip)
            if svc:
                self.ip_known[ip] = svc


