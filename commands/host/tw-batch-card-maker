#!/usr/bin/env bash
#ddev-generated
#annertech-ddev

## Description: Create cards in bulk across Teamwork support projects
## Usage: tw-batch-card-maker
## Example: "ddev tw-batch-card-maker"

set -eo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
echo_red()    { echo -e "${RED}$1${NC}" >&2; }
echo_green()  { echo -e "${GREEN}$1${NC}"; }
echo_yellow() { echo -e "${YELLOW}$1${NC}"; }

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib"
. "$LIB_DIR/tw-curl.sh"

TW_API_KEY="${TEAMWORK_API_KEY:-}"
DOMAIN="${TEAMWORK_DOMAIN:-}"
if [[ -z "$TW_API_KEY" || -z "$DOMAIN" ]]; then
    echo_red "Error: TEAMWORK_API_KEY and TEAMWORK_DOMAIN must be set"
    exit 1
fi

MISSING_DEPS=()
command -v jq  &>/dev/null || MISSING_DEPS+=("jq")
command -v fzf &>/dev/null || MISSING_DEPS+=("fzf")
if [[ ${#MISSING_DEPS[@]} -gt 0 ]]; then
    echo_red "Error: missing dependencies: ${MISSING_DEPS[*]}"
    exit 1
fi

read -e -r -p "$(echo -e "${YELLOW}Card title [Maintenance and Updates]: ${NC}")" CARD_TITLE
CARD_TITLE="${CARD_TITLE:-Maintenance and Updates}"

echo_yellow "Enter description (Ctrl+D on empty line to finish, blank for none):"
CARD_DESC=""
while IFS= read -r line; do
    CARD_DESC+="${line}"$'\n'
done
CARD_DESC="${CARD_DESC%$'\n'}"

echo_yellow "Fetching available tags..."
TAGS_RESPONSE=$(tw_curl -s "https://${DOMAIN}/tags.json")
TAG_LIST=$(echo "$TAGS_RESPONSE" | jq -r '.tags[] | "\(.id)\t\(.name)"')

TAG_IDS_JSON="[]"
if [[ -n "$TAG_LIST" ]]; then
    TAG_SELECTION=$(echo "$TAG_LIST" | \
        fzf --multi \
            --reverse \
            --height=50% \
            --header="Select tags (Tab: toggle | Enter: confirm, skip to add none)" \
            --bind="ctrl-a:select-all" \
            --delimiter=$'\t' \
            --with-nth=2 \
            --prompt="Tags > ")
    if [[ -n "$TAG_SELECTION" ]]; then
        TAG_IDS_JSON=$(echo "$TAG_SELECTION" | cut -f1 | jq -Rs '[split("\n")[] | select(length > 0) | tonumber]')
    fi
else
    echo_yellow "No tags found, skipping."
fi

echo_yellow "Fetching active Teamwork projects..."
RESPONSE=$(tw_curl -s "https://${DOMAIN}/projects.json?status=active")

if [[ -z "$RESPONSE" ]]; then
    echo_red "Error: Failed to fetch projects"
    exit 1
fi

STATUS=$(echo "$RESPONSE" | jq -r '.STATUS')
if [[ "$STATUS" != "OK" ]]; then
    echo_red "Error: $(echo "$RESPONSE" | jq -r '.MESSAGE // "Unknown error"')"
    exit 1
fi

# Filter projects with "support" in name (case-insensitive)
SUPPORT_PROJECTS=$(echo "$RESPONSE" | \
    jq -r '.projects[] | select(.name | ascii_downcase | contains("support")) | "\(.id)\t\(.name)"')

if [[ -z "$SUPPORT_PROJECTS" ]]; then
    echo_red "No support projects found"
    exit 1
fi

PROJECT_COUNT=$(echo "$SUPPORT_PROJECTS" | wc -l)
echo_yellow "Found ${PROJECT_COUNT} support project(s)."
echo ""

# Multi-select TUI
SELECTED=$(echo "$SUPPORT_PROJECTS" | \
    fzf --multi \
        --reverse \
        --height=70% \
        --header="Tab: toggle | Ctrl+A: select all | Ctrl+D: select none | Enter: confirm" \
        --bind="ctrl-a:select-all,ctrl-d:deselect-all" \
        --delimiter=$'\t' \
        --with-nth=2 \
        --prompt="Select projects > ")

if [[ -z "$SELECTED" ]]; then
    echo_red "Nothing selected. Aborting."
    exit 0
fi

SELECTED_COUNT=$(echo "$SELECTED" | wc -l)
echo ""
echo_yellow "Creating '${CARD_TITLE}' in ${SELECTED_COUNT} project(s)..."
echo ""

RESULTS=()
FAILURES=()

while IFS=$'\t' read -r PROJECT_ID PROJECT_NAME; do
    # Fetch tasklists for project
    TL_RESPONSE=$(tw_curl -s "https://${DOMAIN}/projects/${PROJECT_ID}/tasklists.json")

    if [[ -z "$TL_RESPONSE" ]]; then
        echo_red "  ✗ ${PROJECT_NAME}: failed to fetch tasklists"
        FAILURES+=("$PROJECT_NAME")
        continue
    fi

    TL_STATUS=$(echo "$TL_RESPONSE" | jq -r '.STATUS')
    if [[ "$TL_STATUS" != "OK" ]]; then
        echo_red "  ✗ ${PROJECT_NAME}: $(echo "$TL_RESPONSE" | jq -r '.MESSAGE // "API error"')"
        FAILURES+=("$PROJECT_NAME")
        continue
    fi

    # Use "Cards" tasklist (case-insensitive); fall back to first available
    TASKLIST_ID=$(echo "$TL_RESPONSE" | jq -r '
        (.tasklists // []) |
        (map(select(.name | ascii_downcase | contains("cards"))) | first // .[0]) |
        .id // empty')

    if [[ -z "$TASKLIST_ID" ]]; then
        echo_red "  ✗ ${PROJECT_NAME}: no tasklist found"
        FAILURES+=("$PROJECT_NAME")
        continue
    fi

    DATA=$(jq -n --arg name "$CARD_TITLE" --arg desc "$CARD_DESC" --argjson tags "$TAG_IDS_JSON" \
        '{"todo-item": {"content": $name, "description": $desc, "tag-ids": $tags}}')

    CREATE_RESPONSE=$(tw_curl -s -w "\n%{http_code}" -X POST \
        -H "Content-Type: application/json" \
        -d "$DATA" \
        "https://${DOMAIN}/tasklists/${TASKLIST_ID}/tasks.json")

    HTTP_CODE=$(echo "$CREATE_RESPONSE" | tail -n1)
    BODY=$(echo "$CREATE_RESPONSE" | head -n-1)

    if [[ "$HTTP_CODE" -eq 201 || "$HTTP_CODE" -eq 200 ]]; then
        TASK_ID=$(echo "$BODY" | jq -r '.id')
        TASK_URL="https://${DOMAIN}/tasks/${TASK_ID}"
        echo_green "  ✓ ${PROJECT_NAME}"
        RESULTS+=("${PROJECT_NAME}"$'\t'"${TASK_URL}")
    else
        echo_red "  ✗ ${PROJECT_NAME}: HTTP ${HTTP_CODE}"
        FAILURES+=("$PROJECT_NAME")
    fi
done <<< "$SELECTED"

# Summary
echo ""
if [[ ${#RESULTS[@]} -gt 0 ]]; then
    echo_green "=== Cards Created ==="
    for entry in "${RESULTS[@]}"; do
        IFS=$'\t' read -r name url <<< "$entry"
        echo "${name}, ${url}"
    done
fi

if [[ ${#FAILURES[@]} -gt 0 ]]; then
    echo ""
    echo_red "=== Failed ==="
    for name in "${FAILURES[@]}"; do
        echo_red "  - ${name}"
    done
fi
