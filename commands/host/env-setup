#!/usr/bin/env bash
#ddev-generated
#annertech-ddev

## Description: Configure project settings (Teamwork board, live/build mode)
## Usage: env-setup
## Example: "ddev env-setup"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; NC='\033[0m'
echo_red()    { echo -e "${RED}$1${NC}" >&2; }
echo_green()  { echo -e "${GREEN}$1${NC}"; }
echo_yellow() { echo -e "${YELLOW}$1${NC}"; }

LIB_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib"
. "$LIB_DIR/tw-projects.sh"

set_teamwork_board() {
    tw_select_project
    ddev dotenv set .ddev/.env.anner --teamwork-project-id="$PROJECT_ID"
    echo_green "✓ Saved TEAMWORK_PROJECT_ID=$PROJECT_ID ($PROJECT_NAME) to .ddev/.env.anner"
}

OPTIONS=(
    "1. Set Teamwork Board"
    "2. Set Project to LIVE mode"
    "3. Set Project to BUILD mode"
)

set_live_mode() {
    ddev dotenv set .ddev/.env.anner --live=1
    echo_green "✓ Set project to LIVE mode (LIVE=1)"
}

set_build_mode() {
    ddev dotenv set .ddev/.env.anner --live=0
    echo_green "✓ Set project to BUILD mode (LIVE=0)"
}

main() {
    local selection
    selection=$(printf '%s\n' "${OPTIONS[@]}" | fzf --reverse --height=50% --header="Project Setup" -1)

    if [[ -z "$selection" ]]; then
        echo_red "Nothing selected. Exiting."
        exit 0
    fi

    case "$selection" in
        "1."*) set_teamwork_board ;;
        "2."*) set_live_mode ;;
        "3."*) set_build_mode ;;
        *) echo_red "Unknown selection"; exit 1 ;;
    esac
}

main "$@"
