#!/usr/bin/env bash
#ddev-generated
#annertech-ddev

## Description: AI Prompts Operations Centre
## Usage: ai-prompts
## Example: "ddev ai-prompts"
## Aliases: ai

# ------------------------------------------------------------------------------
# Access Log Forensics - GDPR note
# ------------------------------------------------------------------------------
# Access logs contain client IP addresses, which are personal data under GDPR.
# Sending them to a US-hosted LLM without safeguards is a transfer violation.
#
# Before the log is handed to any agent, IPv4 addresses are replaced with
# prefix-preserving pseudonyms:
#   - IPs in the same /8, /16 or /24 in the real log share the same masked
#     /8, /16 or /24 - so subnet-based analysis (botnet detection, CIDR blocks
#     to recommend) still works correctly.
#   - The mapping is random per run and never leaves the machine.
#   - A sidecar TSV is written next to the source log at
#     `<log_dir>/.ip_mapping_<timestamp>.tsv` (chmod 600). Grep a masked IP
#     in that file to recover the real one for blocklist application.
#   - The masked copy passed to the LLM lives in /tmp and is deleted after.
#   - IPv6 addresses are NOT masked yet; a warning is printed if any are
#     detected. Do not run this on IPv6-heavy logs until that's handled.
#   - Note that WHOIS / ASN / geolocation steps cannot be run against masked
#     IPs - the prompt has been adjusted accordingly.
# ------------------------------------------------------------------------------

# Colours
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo_red() { echo -e "${RED}$1${NC}" >&2; }
echo_green() { echo -e "${GREEN}$1${NC}" >&2; }
echo_yellow() { echo -e "${YELLOW}$1${NC}" >&2; }

# Menu options
OPTIONS=(
    "1. BackstopJS Init"
    "2. Access Log Forensics (GDPR-safe: IPv4 masked, mapping kept locally)"
)

# AI Agent options
AI_AGENTS=(
    "1. Gemini"
    "2. Copilot"
    "3. Claude"
)

# Select action
select_action() {
    echo_green "Start typing to select a prompt"
    printf '%s\n' "${OPTIONS[@]}" | fzf --reverse --height=50% --header="AI Prompt"
}

# Select AI agent
select_agent() {
    echo_green "Select AI agent"
    printf '%s\n' "${AI_AGENTS[@]}" | fzf --reverse --height=50% --header="AI Agent"
}

# BackstopJS Init function
backstop_init() {
    # Extract environment variables from DDEV container
    TEST_DOMAIN=$(ddev exec env | grep -E '^DDEV_PRIMARY_URL=' | cut -d= -f2)
    REFERENCE_DOMAIN=$(ddev exec env | grep -E '^STAGE_FILE_PROXY_URL=' | cut -d= -f2)

    # Validate variables
    if [ -z "$TEST_DOMAIN" ]; then
        echo_red "Error: DDEV_PRIMARY_URL not found"
        exit 1
    fi

    if [ -z "$REFERENCE_DOMAIN" ]; then
        echo_red "Error: STAGE_FILE_PROXY_URL not found"
        exit 1
    fi

    # Change to tests/backstop directory
    if ! cd tests/backstop 2>/dev/null; then
        echo_red "Error: tests/backstop directory not found"
        exit 1
    fi

    # Select AI agent
    local agent_selection
    agent_selection=$(select_agent)
    if [[ -z "$agent_selection" ]]; then
        echo_red "No agent selected... Exiting"
        exit 0
    fi

    # Extract agent label
    local agent_label
    agent_label=$(echo "$agent_selection" | sed 's/^[0-9]*\. //')

    echo_green "Initializing BackstopJS configuration with ${agent_label}..."
    echo ""

    # Read and populate the prompt
    local prompt_content
    prompt_content=$(sed -e "s|__TEST_DOMAIN__|$TEST_DOMAIN|g" \
        -e "s|__REFERENCE_DOMAIN__|$REFERENCE_DOMAIN|g" \
        ../../.ddev/scripts/prompts/backstop-init.md)

    # Call the selected AI agent
    case "$agent_label" in
        "Gemini")
            gemini "$prompt_content"
            ;;
        "Copilot")
            copilot "$prompt_content"
            ;;
        "Claude")
            claude --model sonnet --effort low "$prompt_content"
            ;;
        *)
            echo_red "Unknown agent: $agent_label"
            exit 1
            ;;
    esac
}

# Access Log Forensics function
access_log_forensics() {
    # Pick a log file from ./logs/ directory, fallback to manual input
    local log_file
    local log_files
    log_files=$(find logs -maxdepth 1 \( -name "*_access.log" -o -name "*_access.log.gz" \) 2>/dev/null)

    if [[ -n "$log_files" ]]; then
        log_file=$(echo "$log_files" | fzf --reverse --height=50% --header="Select access log file")
    fi

    if [[ -z "$log_file" ]]; then
        echo_yellow "No access log files found in logs/. Enter path manually:"
        read -r log_file
    fi

    if [[ -z "$log_file" || ! -f "$log_file" ]]; then
        echo_red "File not found: $log_file"
        exit 1
    fi

    # If the file is gzipped, decompress to a temp file
    local work_file="$log_file"
    local tmp_file=""
    if [[ "$log_file" == *.gz ]]; then
        tmp_file=$(mktemp /tmp/access_log_XXXXXX.log)
        echo_yellow "Decompressing ${log_file}..."
        if ! gunzip -c "$log_file" > "$tmp_file"; then
            echo_red "Failed to decompress: $log_file"
            rm -f "$tmp_file"
            exit 1
        fi
        work_file="$tmp_file"
    fi

    # Select AI agent
    local agent_selection
    agent_selection=$(select_agent)
    if [[ -z "$agent_selection" ]]; then
        echo_red "No agent selected... Exiting"
        rm -f "$tmp_file"
        exit 0
    fi

    local agent_label
    agent_label=$(echo "$agent_selection" | sed 's/^[0-9]*\. //')

    # GDPR: mask IPs before sending to LLM. Prefix-preserving pseudonymization
    # keeps subnet structure (so botnet /24 patterns are still detectable) while
    # stripping the real IPs. Mapping kept locally for reverse lookup.
    mkdir -p /tmp/anrt-ddev
    local masked_file
    masked_file=$(mktemp /tmp/anrt-ddev/access_log_masked_XXXXXX.log)
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    local log_dir
    log_dir=$(dirname "$log_file")
    local mapping_file="${log_dir}/.ip_mapping_${timestamp}.tsv"

    echo_yellow "Masking IPs (prefix-preserving) before LLM submission..."
    if ! python3 "${DDEV_APPROOT}/.ddev/commands/host/_lib/mask_ips.py" \
        "$work_file" "$masked_file" "$mapping_file"; then
        echo_red "IP masking failed - aborting to avoid leaking real IPs."
        rm -f "$tmp_file" "$masked_file"
        exit 1
    fi
    echo_green "Mapping: ${mapping_file} (chmod 600). Grep a masked IP to recover the real one."

    echo_green "Running Access Log Forensics with ${agent_label} on masked copy of ${log_file}..."
    echo ""

    # Mapping basename is what both the LLM (cwd=./logs) and the user
    # (after `cd logs`) will use. Keeping it basename-only lets the sed
    # command the LLM emits stay short and copy-pasteable.
    local mapping_basename
    mapping_basename=$(basename "$mapping_file")

    local prompt_content
    prompt_content=$(sed -e "s|__ACCESS_LOG_FILE__|$masked_file|g" \
        -e "s|__MAPPING_FILE__|$mapping_basename|g" \
        "${DDEV_APPROOT}/.ddev/scripts/prompts/access-log-forensics.md")

    # Run the LLM with cwd=./logs (mirrors backstop_init's cd into tests/backstop).
    # The masked log lives in /tmp (absolute path in the prompt) so it's still
    # reachable; the LLM's cwd is just scoped to the logs directory.
    if ! (cd "$log_dir" && case "$agent_label" in
        "Gemini")
            gemini "$prompt_content"
            ;;
        "Copilot")
            copilot "$prompt_content"
            ;;
        "Claude")
            claude --model sonnet --effort low "$prompt_content"
            ;;
        *)
            echo_red "Unknown agent: $agent_label"
            exit 1
            ;;
    esac); then
        rm -f "$tmp_file" "$masked_file"
        exit 1
    fi

    rm -f "$tmp_file" "$masked_file"
}

# Main function
main() {
    # Banner
    echo_green "AI-Powered Operations"
    echo "Prompts by Annertech"
    echo "and Bill Seremetis"
    echo ""

    # Select action
    local action_selection
    action_selection=$(select_action)
    if [[ -z "$action_selection" ]]; then
        echo_red "Nothing selected... Exiting"
        exit 0
    fi

    # Extract action from selection (remove number prefix)
    local action_label
    action_label=$(echo "$action_selection" | sed 's/^[0-9]*\. //')

    echo ""

    # Execute selected action
    case "$action_label" in
        "BackstopJS Init")
            backstop_init
            ;;
        "Access Log Forensics "*)
            access_log_forensics
            ;;
        *)
            echo_red "Unknown action: $action_label"
            exit 1
            ;;
    esac
}

main
