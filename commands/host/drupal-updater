# Determine docroot or fallback to web
if [ -z ${DDEV_DOCROOT+x} ]; then
  PROJECT_DOCROOT=web # Sensible default value
else
  PROJECT_DOCROOT=$DDEV_DOCROOT
fi

# Function to create a snapshot
create_snapshot() {
  if [ -z "$omit_snapshot" ]; then
    ddev snapshot
  fi
}

# Function to ensure the current branch is recreated from the from-branch
ensure_from_branch() {
  local FROM_BRANCH_NAME=$1
  local CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

  if [ "$CURRENT_BRANCH" != "$FROM_BRANCH_NAME" ]; then
    echo "Resetting current branch $CURRENT_BRANCH from $FROM_BRANCH_NAME"
    # Reset the branch from the target branch
    git clean -f -d
    git fetch origin
    git reset --hard "origin/$FROM_BRANCH_NAME"
  else
    echo "Current branch is already $FROM_BRANCH_NAME, nothing to do."
  fi
}

# Function to update a single module
update_module() {
  local MODULE_NAME=$1

  # Get the current version before updating
  local FROM_VERSION
  FROM_VERSION=$(ddev composer show "$MODULE_NAME" 2>/dev/null | awk '/^versions/ {print $NF}')

  if [ "$dry_run" = true ]; then
    ddev composer update "$MODULE_NAME" --with-all-dependencies --dry-run
  else
    # Run the update
    ddev composer update "$MODULE_NAME" --with-all-dependencies --bump-after-update --no-progress --quiet

    # Get the updated version after the update
    local MODULE_VERSION
    MODULE_VERSION=$(ddev composer show "$MODULE_NAME" 2>/dev/null | awk '/^versions/ {print $NF}')

    # Check if the version has changed
    if [ "$FROM_VERSION" = "$MODULE_VERSION" ]; then
      echo "No update needed for $MODULE_NAME. The version is already $MODULE_VERSION."
    else
      # Run drush commands if there was an update
      if [ "$updb" = true ]; then
        ddev drush updb -y
        ddev drush cex -y
      fi

      # Commit if --commit-steps flag is provided
      if [ "$commit_steps" = true ]; then
        git add -u
        git add vendor/
        # Strip drupal prefix to get installation path
        git add ${PROJECT_DOCROOT}/modules/contrib${MODULE_NAME#drupal}
        git add config/
        git commit -m "$MODULE_NAME updated from $FROM_VERSION to $MODULE_VERSION (#drupal-updater)"

        # Commit any remaining changes in modules/contrib/ (e.g. updated dependencies)
        if git status --short "${PROJECT_DOCROOT}/modules/contrib/" | grep -q .; then
          git add ${PROJECT_DOCROOT}/modules/contrib/
          git commit -m "$MODULE_NAME updated from $FROM_VERSION to $MODULE_VERSION (#drupal-updater) EXTRA FILES"
        fi
      fi
    fi
  fi
}

# Function to update the core metapackage SET together.
# Drupal projects pin core-recommended to an EXACT version (e.g. 11.3.10), which
# composer update cannot move past. Core must be bumped with `composer require`,
# and all installed core metapackages must move together or composer cannot resolve.
update_core() {
  # Real version lives on drupal/core itself, present in every install
  local FROM_VERSION
  FROM_VERSION=$(ddev composer show drupal/core 2>/dev/null | awk '/^versions/ {print $NF}')

  # Installed core metapackages we directly require (exclude plain drupal/core)
  local CORE_METAPACKAGES
  CORE_METAPACKAGES=$(ddev composer show 2>/dev/null | awk '$1 ~ /^drupal\/core-/ {print $1}')
  if [ -z "$CORE_METAPACKAGES" ]; then
    echo "No core metapackages found to update."
    return
  fi

  # Latest stable version available (ignore -dev branches), highest by version sort
  local TARGET
  TARGET=$(ddev composer show drupal/core-recommended --all --format=json 2>/dev/null \
    | grep -oE '"[0-9]+\.[0-9]+\.[0-9]+"' | tr -d '"' | sort -V | tail -n1)
  if [ -z "$TARGET" ]; then
    echo "Could not determine latest core version."
    return
  fi

  if [ "$FROM_VERSION" = "$TARGET" ]; then
    echo "No update needed for Drupal core. The version is already $TARGET."
    return
  fi

  # Build "pkg:~TARGET" require args so future patch releases are allowed
  local REQUIRE_ARGS=()
  local PKG
  for PKG in $CORE_METAPACKAGES; do
    REQUIRE_ARGS+=("$PKG:~$TARGET")
  done

  echo "Requiring Drupal core ~$TARGET (from $FROM_VERSION)"
  if [ "$dry_run" = true ]; then
    ddev composer require "${REQUIRE_ARGS[@]}" --update-with-all-dependencies --dry-run
    return
  fi

  ddev composer require "${REQUIRE_ARGS[@]}" --update-with-all-dependencies --no-progress

  local CORE_VERSION
  CORE_VERSION=$(ddev composer show drupal/core 2>/dev/null | awk '/^versions/ {print $NF}')

  if [ "$FROM_VERSION" = "$CORE_VERSION" ]; then
    echo "No update needed for Drupal core. The version is already $CORE_VERSION."
    return
  fi

  if [ "$updb" = true ]; then
    ddev drush updb -y
    ddev drush cex -y
  fi

  if [ "$commit_steps" = true ]; then
    git add -u
    # Stage NEW files too (git add -u only tracks already-tracked paths)
    git add vendor/
    git add "${PROJECT_DOCROOT}/core"
    git add config/
    git commit -m "Drupal core updated from $FROM_VERSION to $CORE_VERSION (#drupal-updater)"
  fi
}

# Function to list ALL packages that have a security advisory
security_packages_all() {
  ddev composer audit --locked --format=json 2>/dev/null \
    | grep -oE '"packageName": *"[^"]+"' \
    | awk -F'"' '{print $4}' \
    | sort -u
}

# Function to update all modules and core based on flags
update_all_modules() {
  local MODULES need_core=false

  if [ "$security_only" = true ]; then
    local ADVISORIES
    ADVISORIES=$(security_packages_all)
    # Contrib/custom drupal modules with advisories
    MODULES=$(echo "$ADVISORIES" | grep "^drupal/" | grep -v "^drupal/core")
    # Core advisory directly, OR a core dependency (symfony/*, twig/*, etc.) advisory
    if echo "$ADVISORIES" | grep -q "^drupal/core"; then
      need_core=true
    elif echo "$ADVISORIES" | grep -vq "^drupal/"; then
      # A non-drupal advisory (symfony/*, twig/*, ...) is a core dependency
      echo "Non-Drupal advisory found (e.g. symfony/twig) — updating core to pull fixed dependencies."
      need_core=true
    fi
  else
    # Only packages that actually have a pending update (not all installed)
    MODULES=$(ddev composer outdated --direct --minor-only | grep "drupal/" | grep -v "drupal/core" | awk '{print $1}')
    if [ "$with_core" = true ] && ddev composer outdated --minor-only | grep -q "^drupal/core"; then
      need_core=true
    fi
  fi

  if [ -z "$MODULES" ] && [ "$need_core" != true ]; then
    echo "Nothing to update."
    return
  fi

  for MODULE in $MODULES; do
    echo "Updating: $MODULE"
    update_module "$MODULE"
  done

  if [ "$need_core" = true ]; then
    echo "Updating: Drupal core"
    update_core
  fi
}

# Parse flags and arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    -*) # Handle grouped short options like -cugado
      OPTS="${1:1}" # Remove leading dash
      for (( i=0; i<${#OPTS}; i++ )); do
        opt="${OPTS:$i:1}"
        case $opt in
          c) with_core=true ;;
          g) commit_steps=true ;;
          a) action="update_all" ;;
          d) updb=true ;;
          o) omit_snapshot=true ;;
          s) security_only=true; action="update_all" ;;
          *) echo "WARN: Unknown option -$opt" ;;
        esac
      done
      shift
      ;;
    --commit-steps) commit_steps=true; shift ;;
    --with-core) with_core=true; shift ;;
    --all) action="update_all"; shift ;;
    --dry-run) dry_run=true; shift ;;
    --omit-snapshot) omit_snapshot=true; shift ;;
    --run-db-updates) updb=true; shift ;;
    --security-only) security_only=true; action="update_all"; shift ;;
    --) shift; break ;;
    *) break ;;
  esac
done

if [ "$action" = "update_all" ]; then
  create_snapshot
  update_all_modules
else
  create_snapshot
  update_module "$1"
fi
