TW_API_KEY="${TEAMWORK_API_KEY}"
DOMAIN="${TEAMWORK_DOMAIN}"

if [[ -z "$TW_API_KEY" || -z "$DOMAIN" ]]; then
  echo_red "Error: TEAMWORK_API_KEY and TEAMWORK_DOMAIN environment variables must be set."
  exit 1
fi

# Ask for card URL
if [[ -n "$1" ]]; then
  CARD_URL="$1"
else
  read -e -p "Enter Teamwork card URL: " CARD_URL
fi

if [[ -z "$CARD_URL" ]]; then
  echo_red "Error: No card URL provided."
  exit 1
fi

# Extract task ID from URL
if [[ $CARD_URL =~ ([0-9]+)$ ]]; then
  TASK_ID="${BASH_REMATCH[1]}"
else
  echo_red "Error: Could not extract a task ID from: $CARD_URL"
  exit 1
fi

# Fetch card title via Teamwork API
printf "  %-50s" "Fetching card title..."
API_RESPONSE=$(tw_curl -s "https://${DOMAIN}/tasks/${TASK_ID}.json")
TITLE=$(echo "$API_RESPONSE" | jq -r '."todo-item".content' 2>/dev/null)
if [[ -z "$TITLE" || "$TITLE" == "null" ]]; then
  echo -e " ${RED}‚úó${NC}"
  echo_red "Error: Could not fetch card title. Check your API credentials and task ID."
  exit 1
fi
